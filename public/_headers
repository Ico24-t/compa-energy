# Security and CORS headers for Cloudflare Pages
# This file ensures proper email sending from mobile devices

/*
  # Security Headers
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  
  # CORS Headers - Essential for EmailJS on mobile
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization, X-Requested-With
  Access-Control-Max-Age: 86400
  
  # Content Security Policy - Allow EmailJS domains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdn.emailjs.com; connect-src 'self' https://api.emailjs.com https://*.supabase.co wss://*.supabase.co; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; frame-ancestors 'none';
  
  # Cache Control
  Cache-Control: public, max-age=0, must-revalidate

# Static assets - longer cache
/static/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker
/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate
